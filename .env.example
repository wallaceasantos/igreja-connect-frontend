# ================================================================
# IGREJA CONNECT - Variáveis de Ambiente
# ================================================================
# Copie este arquivo para .env.local e preencha com seus dados
# Domínio: ccjv.com.br
# ================================================================

# ================================================================
# APP
# ================================================================
VITE_APP_NAME=Igreja Connect
VITE_APP_DESCRIPTION=Plataforma digital para igrejas
VITE_APP_URL=https://ccjv.com.br

# ================================================================
# API BACKEND
# ================================================================
# URL da API PHP (backend na HostGator)
VITE_API_URL=https://ccjv.com.br/api

# Proxy para desenvolvimento (vite.config.ts)
VITE_API_PROXY_TARGET=http://localhost:8080

# ================================================================
# BANCO DE DADOS (Backend PHP - HostGator)
# ================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=igreja_connect
DB_USER=seu_usuario_banco
DB_PASS=sua_senha_banco
DB_CHARSET=utf8mb4

# ================================================================
# YOUTUBE
# ================================================================
# ID do canal YouTube (para integração de lives)
VITE_YOUTUBE_CHANNEL=

# ================================================================
# GOOGLE ANALYTICS 4
# ================================================================
# Opcional - deixe vazio se não usar GA
VITE_GA_ID=

# ================================================================
# DOMÍNIOS
# ================================================================
# Domínio principal da plataforma
VITE_MAIN_DOMAIN=ccjv.com.br

# ================================================================
# PAGAMENTOS (Stripe / Mercado Pago)
# ================================================================
# Stripe (Teste)
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# ================================================================
# EMAIL (SMTP - HostGator)
# ================================================================
MAIL_HOST=smtp.hostgator.com.br
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@ccjv.com.br
MAIL_FROM_NAME=Igreja Connect

# ================================================================
# TELEGRAM BOT (Notificações)
# ================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ================================================================
# SEGURANÇA
# ================================================================
# Chave secreta para JWT e sessões
JWT_SECRET=mude_esta_chave_secreta_em_producao

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# ================================================================
# DESENVOLVIMENTO
# ================================================================
# Debug mode (não usar em produção!)
VITE_DEBUG=true
